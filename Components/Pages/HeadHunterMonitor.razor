@page "/headhunter-monitor"
@rendermode InteractiveServer
@using HeadHunterJobPopularTagsMonitor.Constants
@using HeadHunterJobPopularTagsMonitor.Services
@implements IDisposable;

<PageTitle>Job tags monitor</PageTitle>

<h3>HeadHunter job tags monitor</h3>
<EditForm EditContext="_editContext">
	<div>
		<label>
			Job name:
			<InputText id="jobName" @bind-value="_jobName" placeholder="Job name" disabled="@_isLoading"/>
		</label>
	</div>

	<div>
		<label>
			Number of vacancies in selection
			<InputNumber id="vacanciesCount" @bind-value="_vacanciesCount" disabled="@_isLoading" @onchange="OnVacancyCountFieldChange" />
		</label>
	</div>
	<div>
		<p style="color: gray">Note: The more vacancies you want to analyze, the longer the search will take. Maximum number of vacancies is @HeadHunterApiConstants.MaxVacanciesInRequest</p>
        <p style="color: gray">Note: If you want to stop the search, just click the button again :)</p>
	</div>
	<div>
        <ValidationMessage For="@(() => _jobName)" />
        <ValidationMessage For="@(() => _vacanciesCount)" />
	</div>
	<div>
		<button class="btn btn-primary" @onclick="() => GetPopularJobTagsAsync(_jobName, _vacanciesCount)">@_searchButtonText</button>
	</div>
</EditForm>


@{
	if (_isValidationFailed)
	{
		foreach (string error in _validationErrorMessages)
		{
			<p style="color: red">@error</p>
		}
	}

	if (_isLoading)
	{
		<p><em>Loading...</em></p>

	}
	else if (_jobTags.Count > 0)
	{
		<table>
			<thead>
				<tr>
					<th>Tag name</th>
					<th>Count</th>
				</tr>
			</thead>
			<tbody>
				@foreach (var tag in _jobTags)
				{
					<tr>
						<th>@tag.Key</th>
						<th>@tag.Value</th>
					</tr>
				}
			</tbody>
		</table>
	}
	else if (_isLoadComplete)
	{
		<p>No vacancies found :(</p>
	}
}

@code
{
	private const string DefaultSearchButtonText = "Find popular tags for job";
	private const string CancelingSearchButtonText = "Cancel search";

	private readonly IJobKeySkillsRequestService _jobKeySkillsRequestService;
	private CancellationTokenSource _cts;
	private bool _isCtsDisposed = false;

	private EditContext? _editContext;

	private string _jobName = "Программист C#";
	private int _vacanciesCount = 100;
	private Dictionary<string, int> _jobTags = new();

	private bool _isLoading = false;
	private bool _isLoadComplete = false;
	private bool _isValidationFailed = false;
	private List<string> _validationErrorMessages = [];
	private string _searchButtonText = DefaultSearchButtonText;

	public HeadHunterMonitor(IJobKeySkillsRequestService jobKeySkillsRequestService)
	{
		_jobKeySkillsRequestService = jobKeySkillsRequestService;
	}

	private async Task GetPopularJobTagsAsync(string jobName, int vacanciesCount)
	{
		if (_isLoading)
		{
			DisposeCancellationTokenSource();
			_searchButtonText = DefaultSearchButtonText;
			_isLoading = false;

			return;
		}

		if (!ValidateInput(jobName, vacanciesCount))
			return;

		_searchButtonText = CancelingSearchButtonText;

		_cts = new();
		_isCtsDisposed = false;

		_isLoadComplete = false;
		_isLoading = true;

		_jobTags = await _jobKeySkillsRequestService.GetKeySkillsForJobAsync(jobName, vacanciesCount, _cts.Token);

		_isLoading = false;
		_isLoadComplete = true;
		_searchButtonText = DefaultSearchButtonText;
	}

	private bool ValidateInput(string jobName, int vacanciesCount)
	{
		bool isValid = true;
		_validationErrorMessages.Clear();

		if (string.IsNullOrWhiteSpace(jobName))
		{
			isValid = false;
			_validationErrorMessages.Add("Job name cannot be empty.");
		}
		if (jobName.Length > 200)
		{
			isValid = false;
			_validationErrorMessages.Add("Job name cannot be longer than 200 characters.");
		}
		if (vacanciesCount <= 0)
		{
			isValid = false;
			_validationErrorMessages.Add("Number of vacancies must be greater than zero.");
		}
		if (vacanciesCount > HeadHunterApiConstants.MaxVacanciesInRequest)
		{
			isValid = false;
			_validationErrorMessages.Add($"Number of vacancies cannot be greater than {HeadHunterApiConstants.MaxVacanciesInRequest}.");
		}

		_isValidationFailed = !isValid;
		return isValid;
	}

	private void OnVacancyCountFieldChange(ChangeEventArgs args)
	{
        //if (args.Value
	}

	public void Dispose()
	{
		DisposeCancellationTokenSource();
	}

	private void DisposeCancellationTokenSource()
	{
		if (_cts is not null && !_isCtsDisposed)
		{
			_cts.Cancel();
			_cts.Dispose();
			_isCtsDisposed = true;
		}
	}
}
